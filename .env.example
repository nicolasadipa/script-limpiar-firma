# ============================================================
# .env.example — Variables de entorno requeridas
# ------------------------------------------------------------
# Copiá este archivo a .env y completá los valores reales.
# El .env NO se commitea (ya está en .gitignore).
# ============================================================

# Token de la API de Monday.com.
# Sacalo desde: monday.com → Avatar → Developers → My Access Tokens
MONDAY_API_TOKEN=

# ID del board que contiene los items con la columna de firmas.
# Lo ves en la URL del board: /boards/<este_numero>
MONDAY_BOARD_ID=
